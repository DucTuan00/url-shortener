generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model Url {
    id          BigInt    @id @default(autoincrement())
    shortCode   String    @unique @map("short_code") @db.VarChar(10)
    originalUrl String    @map("original_url") @db.Text
    customAlias String?   @unique @map("custom_alias") @db.VarChar(50)
    userId      BigInt?   @map("user_id")
    clickCount  BigInt    @default(0) @map("click_count")
    isActive    Boolean   @default(true) @map("is_active")
    expiresAt   DateTime? @map("expires_at") @db.Timestamptz()
    createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
    updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

    clicks Click[]

    @@index([shortCode])
    @@index([userId])
    @@index([expiresAt])
    @@map("urls")
}

model Click {
    id         BigInt   @id @default(autoincrement())
    urlId      BigInt   @map("url_id")
    clickedAt  DateTime @default(now()) @map("clicked_at") @db.Timestamptz()
    ipAddress  String?  @map("ip_address") @db.VarChar(45)
    userAgent  String?  @map("user_agent") @db.Text
    referer    String?  @db.Text
    country    String?  @db.VarChar(2)
    city       String?  @db.VarChar(100)
    deviceType String?  @map("device_type") @db.VarChar(20)
    browser    String?  @db.VarChar(50)
    os         String?  @db.VarChar(50)

    url Url @relation(fields: [urlId], references: [id], onDelete: Cascade)

    @@index([urlId])
    @@index([clickedAt])
    @@map("clicks")
}
