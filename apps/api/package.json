{
    "name": "url-shortener-api",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "tsx watch --require tsconfig-paths/register src/server.ts",
        "build": "tsc && tsc-alias",
        "start": "node dist/server.js",
        "db:migrate": "prisma migrate dev",
        "db:generate": "prisma generate",
        "db:studio": "prisma studio",
        "db:seed": "tsx prisma/seed.ts"
    },
    "dependencies": {
        "@prisma/adapter-pg": "^7.0.0",
        "@prisma/client": "^7.0.0",
        "cors": "^2.8.5",
        "dotenv": "^16.5.0",
        "express": "^4.21.2",
        "helmet": "^8.1.0",
        "nanoid": "^5.1.5",
        "pg": "^8.14.1",
        "zod": "^3.24.3"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.2",
        "@types/node": "^22.14.0",
        "@types/pg": "^8.11.14",
        "prisma": "^7.0.0",
        "tsc-alias": "^1.8.16",
        "tsconfig-paths": "^4.2.0",
        "tsx": "^4.19.4",
        "typescript": "^5.8.3"
    },
    "type": "module"
}